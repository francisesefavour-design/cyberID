# Create the Admin Dashboard template (full CRUD)
admin_html = '''<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Cyber Tech — Admin Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #020408;
      --panel: #0a0f1a;
      --card: #111827;
      --muted: #6b7280;
      --neon: #00ff88;
      --neon-dim: rgba(0, 255, 136, 0.1);
      --accent: #00d4ff;
      --danger: #ff3366;
      --warning: #ffaa00;
      --success: #00ff88;
      --glass: rgba(255, 255, 255, 0.03);
      --border: rgba(255, 255, 255, 0.06);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: var(--bg);
      color: #e5e7eb;
      font-family: 'Inter', sans-serif;
      min-height: 100vh;
    }

    .bg-grid {
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100%;
      background-image: 
        linear-gradient(rgba(0, 255, 136, 0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 255, 136, 0.03) 1px, transparent 1px);
      background-size: 50px 50px;
      pointer-events: none;
      z-index: 0;
    }

    .container-fluid {
      position: relative;
      z-index: 1;
      padding: 40px 20px;
      max-width: 1400px;
      margin: 0 auto;
    }

    /* Header */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 40px;
      padding: 24px;
      background: var(--glass);
      border: 1px solid var(--border);
      border-radius: 16px;
      backdrop-filter: blur(10px);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .brand-icon {
      width: 56px; height: 56px;
      background: linear-gradient(135deg, var(--neon-dim), transparent);
      border: 1px solid rgba(0, 255, 136, 0.2);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      color: var(--neon);
    }

    .brand-text h1 {
      font-size: 24px;
      font-weight: 700;
      color: var(--neon);
      margin: 0;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .brand-text p {
      font-size: 13px;
      color: var(--muted);
      margin: 4px 0 0 0;
    }

    .header-actions {
      display: flex;
      gap: 12px;
    }

    .btn-primary-custom {
      padding: 12px 24px;
      background: linear-gradient(135deg, var(--neon), #00cc6a);
      border: none;
      border-radius: 10px;
      color: #000;
      font-weight: 600;
      font-size: 14px;
      cursor: pointer;
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }

    .btn-primary-custom:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(0, 255, 136, 0.3);
    }

    .btn-secondary-custom {
      padding: 12px 24px;
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 10px;
      color: var(--muted);
      font-weight: 500;
      font-size: 14px;
      cursor: pointer;
      transition: all 0.3s ease;
      text-decoration: none;
    }

    .btn-secondary-custom:hover {
      border-color: var(--danger);
      color: var(--danger);
    }

    /* Alert */
    .alert {
      padding: 16px 20px;
      border-radius: 10px;
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .alert-success {
      background: rgba(0, 255, 136, 0.1);
      border: 1px solid rgba(0, 255, 136, 0.3);
      color: var(--success);
    }

    .alert-danger {
      background: rgba(255, 51, 102, 0.1);
      border: 1px solid rgba(255, 51, 102, 0.3);
      color: var(--danger);
    }

    /* Table */
    .table-container {
      background: var(--glass);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      backdrop-filter: blur(10px);
    }

    .table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      margin: 0;
    }

    .table thead {
      background: rgba(0, 0, 0, 0.3);
    }

    .table th {
      padding: 20px;
      text-align: left;
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      border-bottom: 1px solid var(--border);
    }

    .table td {
      padding: 20px;
      border-bottom: 1px solid var(--border);
      font-size: 14px;
      vertical-align: middle;
    }

    .table tbody tr:hover {
      background: rgba(0, 255, 136, 0.03);
    }

    .member-id {
      font-family: 'JetBrains Mono', monospace;
      color: var(--accent);
      font-weight: 600;
      font-size: 13px;
      background: rgba(0, 212, 255, 0.1);
      padding: 6px 12px;
      border-radius: 6px;
      display: inline-block;
    }

    .badge {
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .badge-active {
      background: rgba(0, 255, 136, 0.15);
      color: var(--success);
      border: 1px solid rgba(0, 255, 136, 0.3);
    }

    .badge-pending {
      background: rgba(255, 170, 0, 0.15);
      color: var(--warning);
      border: 1px solid rgba(255, 170, 0, 0.3);
    }

    .badge-inactive {
      background: rgba(255, 51, 102, 0.15);
      color: var(--danger);
      border: 1px solid rgba(255, 51, 102, 0.3);
    }

    .progress-bar-bg {
      height: 8px;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 4px;
      overflow: hidden;
      width: 100px;
    }

    .progress-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--neon), var(--accent));
      border-radius: 4px;
      transition: width 0.3s ease;
    }

    .action-btns {
      display: flex;
      gap: 8px;
    }

    .btn-icon {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .btn-icon:hover {
      border-color: var(--accent);
      color: var(--accent);
      background: rgba(0, 212, 255, 0.1);
    }

    .btn-icon.delete:hover {
      border-color: var(--danger);
      color: var(--danger);
      background: rgba(255, 51, 102, 0.1);
    }

    /* Modal */
    .modal-content {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 16px;
      color: #fff;
    }

    .modal-header {
      border-bottom: 1px solid var(--border);
      padding: 24px;
    }

    .modal-title {
      font-size: 20px;
      font-weight: 700;
      color: var(--neon);
    }

    .btn-close {
      filter: invert(1);
      opacity: 0.5;
    }

    .modal-body {
      padding: 24px;
    }

    .form-label {
      font-size: 13px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 8px;
    }

    .form-control, .form-select {
      background: rgba(0, 0, 0, 0.3);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: #fff;
      padding: 12px 16px;
      font-size: 14px;
    }

    .form-control:focus, .form-select:focus {
      background: rgba(0, 0, 0, 0.5);
      border-color: var(--neon);
      box-shadow: 0 0 0 3px rgba(0, 255, 136, 0.1);
      color: #fff;
    }

    .modal-footer {
      border-top: 1px solid var(--border);
      padding: 24px;
    }

    .btn-save {
      padding: 12px 24px;
      background: var(--neon);
      border: none;
      border-radius: 8px;
      color: #000;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .btn-save:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 30px rgba(0, 255, 136, 0.3);
    }

    .verified-checkbox {
      width: 20px;
      height: 20px;
      accent-color: var(--neon);
    }
  </style>
</head>
<body>
  <div class="bg-grid"></div>

  <div class="container-fluid">
    <!-- Header -->
    <div class="header">
      <div class="brand">
        <div class="brand-icon">◈</div>
        <div class="brand-text">
          <h1>Admin Dashboard</h1>
          <p>Manage Cyber Tech Members • CEO Access Only</p>
        </div>
      </div>
      <div class="header-actions">
        <button class="btn-primary-custom" onclick="openAddModal()">+ Add Member</button>
        <a href="{{ url_for('public_view') }}" class="btn-secondary-custom">View Public</a>
        <a href="{{ url_for('logout') }}" class="btn-secondary-custom">Logout</a>
      </div>
    </div>

    <!-- Flash Messages -->
    {% with messages = get_flashed_messages(with_categories=true) %}
      {% if messages %}
        {% for category, message in messages %}
          <div class="alert alert-{{ category }}">
            <span>{{ message }}</span>
          </div>
        {% endfor %}
      {% endif %}
    {% endwith %}

    <!-- Table -->
    <div class="table-container">
      <table class="table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Full Name</th>
            <th>Contact</th>
            <th>Status</th>
            <th>Progress</th>
            <th>Verified</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for member in members %}
          <tr data-id="{{ member.id }}">
            <td><span class="member-id">{{ member.member_id }}</span></td>
            <td>{{ member.full_name }}</td>
            <td>
              <small style="color: var(--muted)">{{ member.email }}<br>{{ member.phone_number }}</small>
            </td>
            <td><span class="badge badge-{{ member.status }}">{{ member.status }}</span></td>
            <td>
              <div class="progress-bar-bg">
                <div class="progress-bar-fill" style="width: {{ member.progress }}%"></div>
              </div>
              <small style="color: var(--muted)">{{ member.progress }}%</small>
            </td>
            <td>{{ '✓ Yes' if member.verified else '✗ No' }}</td>
            <td>
              <div class="action-btns">
                <button class="btn-icon" onclick="openEditModal({{ member.id }}, '{{ member.member_id }}', '{{ member.full_name }}', '{{ member.phone_number }}', '{{ member.email }}', {{ member.progress }}, {{ 'true' if member.verified else 'false' }}, '{{ member.status }}')">✏️</button>
                <button class="btn-icon delete" onclick="deleteMember({{ member.id }})">🗑️</button>
              </div>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Add/Edit Modal -->
  <div class="modal fade" id="memberModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="modalTitle">Add Member</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" id="editId">
          <div class="mb-3">
            <label class="form-label">Member ID</label>
            <input type="text" class="form-control" id="memberId" placeholder="CT-006">
          </div>
          <div class="mb-3">
            <label class="form-label">Full Name</label>
            <input type="text" class="form-control" id="fullName" placeholder="John Doe">
          </div>
          <div class="mb-3">
            <label class="form-label">Phone Number</label>
            <input type="text" class="form-control" id="phoneNumber" placeholder="+234 800 000 0000">
          </div>
          <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" class="form-control" id="email" placeholder="email@cyber.tech">
          </div>
          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label">Progress (%)</label>
              <input type="number" class="form-control" id="progress" min="0" max="100" value="0">
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Status</label>
              <select class="form-select" id="status">
                <option value="active">Active</option>
                <option value="pending">Pending</option>
                <option value="inactive">Inactive</option>
              </select>
            </div>
          </div>
          <div class="mb-3 form-check">
            <input type="checkbox" class="verified-checkbox" id="verified">
            <label class="form-check-label" for="verified" style="margin-left: 8px; color: var(--muted)">Verified Member</label>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-secondary-custom" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn-save" onclick="saveMember()">Save Member</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const modal = new bootstrap.Modal(document.getElementById('memberModal'));
    let isEditing = false;

    function openAddModal() {
      isEditing = false;
      document.getElementById('modalTitle').textContent = 'Add Member';
      document.getElementById('editId').value = '';
      document.getElementById('memberId').value = '';
      document.getElementById('fullName').value = '';
      document.getElementById('phoneNumber').value = '';
      document.getElementById('email').value = '';
      document.getElementById('progress').value = 0;
      document.getElementById('status').value = 'active';
      document.getElementById('verified').checked = false;
      modal.show();
    }

    function openEditModal(id, memberId, fullName, phone, email, progress, verified, status) {
      isEditing = true;
      document.getElementById('modalTitle').textContent = 'Edit Member';
      document.getElementById('editId').value = id;
      document.getElementById('memberId').value = memberId;
      document.getElementById('fullName').value = fullName;
      document.getElementById('phoneNumber').value = phone;
      document.getElementById('email').value = email;
      document.getElementById('progress').value = progress;
      document.getElementById('status').value = status;
      document.getElementById('verified').checked = verified;
      modal.show();
    }

    function saveMember() {
      const data = {
        member_id: document.getElementById('memberId').value,
        full_name: document.getElementById('fullName').value,
        phone_number: document.getElementById('phoneNumber').value,
        email: document.getElementById('email').value,
        progress: parseInt(document.getElementById('progress').value),
        status: document.getElementById('status').value,
        verified: document.getElementById('verified').checked
      };

      const id = document.getElementById('editId').value;
      const url = isEditing ? `/api/members/${id}` : '/api/members';
      const method = isEditing ? 'PUT' : 'POST';

      fetch(url, {
        method: method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          modal.hide();
          location.reload();
        }
      });
    }

    function deleteMember(id) {
      if (confirm('Are you sure you want to delete this member?')) {
        fetch(`/api/members/${id}`, { method: 'DELETE' })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            location.reload();
          }
        });
      }
    }
  </script>
</body>
</html>'''

with open(f"{project_dir}/templates/admin.html", "w") as f:
    f.write(admin_html)

print("✓ Created templates/admin.html")